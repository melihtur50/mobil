{
  "expo": {
    "name": "Tourkia",
    "slug": "tourkia-mobile",
    "version": "1.2.0",
    "owner": "melihtur50",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tourkia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.melihtur.tourkia",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Tourkia, size en yakın anlaşmalı restoranları ve turları göstermek için konumunuza ihtiyaç duyar.",
        "NSCameraUsageDescription": "Tourkia, QR kod biletlerinizi ve voucherlarınızı okumak için kameranıza ihtiyaç duyar.",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafınızı güncellemek için galerinize erişim izni gereklidir."
      }
    },
    "android": {
      "package": "com.melihtur.tourkia",
      "adaptiveIcon": {
        "backgroundColor": "#001A33",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "LOCATION",
        "CAMERA",
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Tourkia, size en yakın restoranları göstermek için konumunuza ihtiyaç duyar."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#001A33"
        }
      ],
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
